{
  "$schema": "http://json.schemastore.org/template",
  "author": "TernaryTechnology",
  "classifications": ["Worker", "Service", "Ternary"],
  "identity": "Ternary.Engine.WorkService",
  "name": "Ternary Engine Work Service",
  "shortName": "ternary-workservice",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "ServiceName",
  "preferNameDirectory": true,
  "symbols": {
    "serviceType": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "Custom",
      "description": "The WorkServiceType enum value for the first Worker. Additional Workers can be added at another time.",
      "choices": [
        { "choice": "Extract",    "description": "Extract structured or unstructured data from source systems to objects" },
        { "choice": "Analyze", "description": "Analyze data from source systems, or extracted objects" },
        { "choice": "Organize",  "description": "Organize, categorize extracted data" },
        { "choice": "Transform",   "description": "Transform extracted data" },
        { "choice": "Map",    "description": "Map extracted data" },
        { "choice": "Validate",    "description": "Validate transformed and mapped data" }
        { "choice": "Import",    "description": "Import validated data into target system" }
        { "choice": "Custom",    "description": "Custom worker service." }
      ]
    },
    "userSecretsId": {
      "type": "generated",
      "generator": "guid",
      "replaces": "REPLACE_USER_SECRETS_ID",
      "parameters": {
        "format": "D"
      }
    }
  }
}
