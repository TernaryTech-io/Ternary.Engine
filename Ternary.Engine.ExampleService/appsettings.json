{
  "Environment": "Development",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }    
  },
  "ServiceOptions": {
    "WorkerIntervalMinutes": 1,
    //Per Worker: Set lower with more workers, higher with less workers.
    "MaxLevelConcurrency": 8,
    "CustomJobsDirectory":  ".customjobs" //Path is relative but can be full path.
  },
  "WorkSteps": [
    /* Example
    {
      "Name": "MySampleStep",
      "ServiceType": "Example",
      "BreakOnSuccess": false,
      "OnSuccessSteps": [
        {
          "Name": "MySuccessStep",
          "ServiceType": "Example"
        }        
      ],
      "BreakOnFailure": true,
      "OnFailureSteps": [
        {
          "Name": "MyFailureStep",
          "Delay": true,
          "ServiceType": "Example"
        }
      ]
    }*/
  ]
}