{
  "Environment": "Development",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ServiceOptions": {
    "DefaultBatchSize": 2000, //Determines how many items are grabbed when a worker executes a WorkStep.
    "WorkerIntervalMinutes": 1, //Pause between worker executions.
    "MaxLevelConcurrency": 8 //This is per Worker, use a higher value for lower Worker count, use a lower value for high Worker count
  },
  //Set Global Properties to be called and used inside your logic.
  "GlobalProperties": {
    "IntakeDirectory": "\\\\share\\intakefiles",
    "IntakeFileFilter": "*.csv",
    "SeedDirectory": "\\\\share\\seeddata",
    "SeedFileFilter": "*.sql"
  },
  "WorkSteps": [
    /* Example Each Service can have a unique workflow.
    Only Top level steps will be run by the "WorkerType", but will queue nested OnSuccessSteps/OnFailureSteps
    {
      "Name": "MySampleStep",
      "WorkerType": "ExampleWorker"
      "BreakOnSuccess": false,
      "OnSuccessSteps": [
        {
          "Name": "MySuccessStep",
          "WorkerType": "SomeOtherWorker"
        }        
      ],
      "BreakOnFailure": true,
      "OnFailureSteps": [
        {
          "Name": "MyFailureStep",
          "WorkerType": "SomeOtherWorker"
          "Delay": true,
        }
      ]
    }*/
  ]
}