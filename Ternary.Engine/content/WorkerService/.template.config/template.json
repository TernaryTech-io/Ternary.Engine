        "fileRename": "MyExample",
        "defaultValue": "MyExample"
    },    
    "userSecretsId": {
      "type": "generated",
      "generator": "guid",
      "replaces": "REPLACE_USER_SECRETS_ID",
      "parameters": {
        "format": "D"
      }
    }
  }
}