{
  "$schema": "http://json.schemastore.org/template",
  "author": "Ternary Technology",
  "classifications": ["Worker", "Service", "Ternary"],
  "identity": "Ternary.Engine.Project",
  "name": "Ternary Worker Service Project",
  "shortName": "ternary-project",
  "sourceName":"MyExample",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "preferNameDirectory": true,
  "symbols": {
    "prefix": {
        "type": "parameter",
        "description": "The prefix of the code files and classes.",
