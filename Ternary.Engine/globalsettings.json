{
  //Duplicate this entire section to create a new environment. Reference the environment in the appsettings.json
  "Development": {
    "DatabaseSettings": {
      "DbConnection": "Data Source=(localdb)\\MSSQLLocalDB;Integrated Security=True;Persist Security Info=False;Pooling=False;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;",
      "Provider": "SqlServer", //Options: SqlServer, PostgreSql, MongoDb, MySql
      "DatabaseName": "TernaryEngine", // Specific to MongoDb, ignored for other providers
      "MigrationAssembly": "Ternary.Engine",
      "ExecutionTimeout": 10, //In Minutes
      "RetryAttempts": 3,
      "MaxBatchSize": 42 //42 is the EFCore default
    },
    "DefaultServiceOptions": {
      "DefaultBatchSize": 2000,
      "WorkerIntervalMinutes": 5,
      "MaxLevelConcurrency": 4,
      "PreprocessingDirectory": ".preprocessing"
    },
    "SplunkLogging": {
      "SplunkUrl": "",
      "SplunkToken": "",
      "MinimumLevel": "Information"
    },
    "FileLogging": {
      "LogPath": ".logs",
      "MinimumLevel": "Information"
    }
  },
  "Mongo": {
    "DatabaseSettings": {
      "DbConnection": "mongodb://admin:password@localhost/?retryWrites=true&w=majority",
      "Provider": "MongoDb", //Options: SqlServer, PostgreSql, MongoDb, MySql
      "DatabaseName": "TernaryEngine", // Specific to MongoDb, ignored for other providers
      "MigrationAssembly": "Ternary.Engine",
      "ExecutionTimeout": 10, //In Minutes
      "RetryAttempts": 3,
      "MaxBatchSize": 42 //42 is the EFCore default
    },
    "DefaultServiceOptions": {
      "DefaultBatchSize": 2000,
      "WorkerIntervalMinutes": 5,
      "MaxLevelConcurrency": 4,
      "PreprocessingDirectory": ".preprocessing"
    },
    "SplunkLogging": {
      "SplunkUrl": "",
      "SplunkToken": "",
      "MinimumLevel": "Information"
    },
    "FileLogging": {
      "LogPath": ".logs",
      "MinimumLevel": "Information"
    }
  }
}