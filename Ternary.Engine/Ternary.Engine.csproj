<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net8.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<RootNamespace>Ternary.Engine</RootNamespace>
		<Title>Ternary Engine</Title>
		<ToolCommandName>engine</ToolCommandName>
	</PropertyGroup>

	<ItemGroup>
	  <Compile Remove="content\DbContext\ExampleDbContext.cs" />
	  <Compile Remove="content\Entity\ExampleEntity.cs" />
	  <Compile Remove="content\Runner\ExampleRunner.cs" />
	  <Compile Remove="content\Service\ExampleService.cs" />
	  <Compile Remove="content\WorkerService\Program.cs" />
	  <Compile Remove="content\Worker\ExampleWorker.cs" />
	</ItemGroup>

	<ItemGroup>
	  <None Remove="content\WorkerService\.gitignore" />
	  <None Remove="content\WorkerService\appsettings.json" />
	  <None Remove="content\WorkerService\README.md" />
	</ItemGroup>

	<ItemGroup>
	  <Content Include="appsettings.json">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	    <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
	    <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
	  </Content>
	  <Content Include="content\DbContext\.template.config\template.json" />
	  <Content Include="content\Entity\.template.config\template.json" />
	  <Content Include="content\Entity\ExampleEntity.cs">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	  <Content Include="content\Runner\.template.config\template.json" />
	  <Content Include="content\Runner\ExampleRunner.cs">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	  <Content Include="content\Service\.template.config\template.json" />
	  <Content Include="content\Service\ExampleService.cs">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	  <Content Include="content\WorkerService\.gitignore">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	  <Content Include="content\WorkerService\.template.config\template.json" />
	  <Content Include="content\WorkerService\appsettings.json">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	  <Content Include="content\WorkerService\Program.cs">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	  <Content Include="content\WorkerService\README.md">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	  <Content Include="content\Worker\.template.config\template.json" />
	  <Content Include="content\Worker\ExampleWorker.cs">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	  <Content Include="globalsettings.json">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	    <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
	    <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
	  </Content>
	</ItemGroup>

  <!--<ItemGroup>
	  <PackageReference Include="Ternary.Engine.Core" Version="1.0.1" />
	</ItemGroup>-->

	<ItemGroup>
	  <ProjectReference Include="..\..\Ternary.Engine.Core\Ternary.Engine.Core.csproj" />
	</ItemGroup>

	<ItemGroup>
    <Using Include="Ternary.Engine.Core" />
    <Using Include="Ternary.Engine.CommandLine" />
    <Using Include="Ternary.Engine.Core.Configuration" />
    <Using Include="Ternary.Engine.Core.Data" />
    <Using Include="Ternary.Engine.Core.Models" />
    <Using Include="Ternary.Engine.Core.Services" />
    <Using Include="Ternary.Engine.Core.Types" />
    <Using Include="Ternary.Engine.Core.Workflow" />
		<Using Include="Microsoft.EntityFrameworkCore" />
		<Using Include="Microsoft.Extensions.Configuration" />
		<Using Include="Microsoft.Extensions.DependencyInjection" />
		<Using Include="Microsoft.Extensions.Hosting" />
		<Using Include="Microsoft.Extensions.Logging" />
		<Using Include="Spectre.Console" />
		<Using Include="Spectre.Console" />
		<Using Include="Spectre.Console.AnsiConsole">
		  <Alias>console</Alias>
		</Using>
	</ItemGroup>

	<ItemGroup>
	  <None Update="content\WorkerService\Properties\launchSettings.json">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </None>
	  <None Update="engine.bat">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </None>
	</ItemGroup>

	<ItemGroup>
	  <Content Include="content\DbContext\ExampleDbContext.cs">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	</ItemGroup>

	<ItemGroup>
	  <Content Include="content\WorkerService\Ternary.Engine.ExampleService.csproj">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Data\" />
	  <Folder Include="Models\" />
	  <Folder Include="Runners\" />
	  <Folder Include="Services\" />
	  <Folder Include="Workers\" />
	</ItemGroup>

</Project>
